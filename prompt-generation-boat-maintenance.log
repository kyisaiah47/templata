<invoke name="Edit">
<parameter name="file_path">/Users/ikim1/Documents/GitHub/templata-boat-maintenance/src/data/prompts-boat-maintenance.ts</parameter>
<parameter name="old_string">  {
    id: 'prompt-36',
    prompt: 'Perform a thorough inspection and lubrication of all steering components, controls, and throttle linkages to ensure smooth operation and identify wear before failure',
    category: 'action',
    helpText: 'Steering and throttle systems are critical for safe boat operation but are often overlooked until they bind or fail at the worst possible moment. Check steering cables for fraying, lubricate all pivot points and connections, and test full range of motion for both steering and throttle controls. This inspection identifies developing problems like stiff cables, worn bushings, or corroded connections before they cause complete system failure, ensuring you maintain full control of your vessel in all operating conditions.'
  }</parameter>
<parameter name="new_string">  {
    id: 'prompt-36',
    prompt: 'Perform a thorough inspection and lubrication of all steering components, controls, and throttle linkages to ensure smooth operation and identify wear before failure',
    category: 'action',
    helpText: 'Steering and throttle systems are critical for safe boat operation but are often overlooked until they bind or fail at the worst possible moment. Check steering cables for fraying, lubricate all pivot points and connections, and test full range of motion for both steering and throttle controls. This inspection identifies developing problems like stiff cables, worn bushings, or corroded connections before they cause complete system failure, ensuring you maintain full control of your vessel in all operating conditions.'
  },
  {
    id: 'prompt-37',
    prompt: 'Test and inspect your boat\'s bilge pump system including float switches, discharge hoses, and backup power sources to ensure reliable water removal capability',
    category: 'action',
    helpText: 'A functioning bilge pump system is your primary defense against taking on water and potential sinking, making this inspection absolutely critical for boat safety. Test both automatic and manual pump operation, check that float switches activate properly, inspect discharge hoses for clogs or damage, and verify battery backup systems are charged and connected. This proactive testing ensures your bilge system will work when needed most and helps you identify problems like clogged strainers, corroded connections, or worn impellers before they leave you vulnerable to water intrusion emergencies.'
  }</parameter>
</invoke>
