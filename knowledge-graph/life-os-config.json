{
  "ui_recommendations": {
    "related_templates_display": {
      "location": "sidebar_right",
      "max_items": 5,
      "show_reasoning": true,
      "group_by_strength": true,
      "trigger": "when_template_selected"
    },
    "cross_prompts_trigger": {
      "minimum_active_templates": 2,
      "show_in": "prompt_suggestions_panel",
      "priority_order": ["connection", "cluster", "sequence"],
      "max_prompts": 3
    },
    "workspace_organization": {
      "default_view": "semantic_clusters",
      "allow_custom_grouping": true,
      "show_life_sequences": true,
      "highlight_active_connections": true
    },
    "template_cards": {
      "show_cluster_badges": true,
      "show_connection_strength": true,
      "highlight_influenced_templates": true,
      "color_code_by_cluster": true
    }
  },
  "ai_insights": {
    "connection_explanations": {
      "enabled": true,
      "show_reasoning": true,
      "explain_psychological_basis": true
    },
    "sequence_guidance": {
      "enabled": true,
      "suggest_next_steps": true,
      "warn_about_prerequisites": true,
      "show_typical_timelines": true
    },
    "influence_warnings": {
      "enabled": true,
      "highlight_major_life_changes": true,
      "suggest_affected_templates": true,
      "show_impact_severity": true
    },
    "cluster_insights": {
      "show_completion_percentage": true,
      "suggest_missing_templates": true,
      "highlight_theme_conflicts": true
    }
  },
  "life_os_features": {
    "multi_template_workspace": {
      "max_simultaneous_templates": 5,
      "auto_suggest_related": true,
      "sync_shared_data": true,
      "cross_reference_decisions": true
    },
    "decision_timeline": {
      "show_life_sequences": true,
      "track_decision_progress": true,
      "suggest_optimal_timing": true,
      "highlight_conflicts": true
    },
    "impact_analysis": {
      "show_ripple_effects": true,
      "calculate_influence_scores": true,
      "suggest_mitigation_strategies": true,
      "track_decision_outcomes": true
    },
    "smart_prompts": {
      "context_aware_suggestions": true,
      "learn_from_user_patterns": true,
      "adapt_to_life_stage": true,
      "personalize_based_on_history": true
    }
  },
  "integration_points": {
    "template_selection": {
      "show_related_on_hover": true,
      "suggest_complementary": true,
      "warn_about_conflicts": true
    },
    "prompt_generation": {
      "include_cross_template_questions": true,
      "prioritize_by_active_templates": true,
      "adapt_to_user_progress": true
    },
    "progress_tracking": {
      "track_across_related_templates": true,
      "show_cluster_completion": true,
      "suggest_next_actions": true
    },
    "export_features": {
      "include_related_templates": true,
      "show_connection_map": true,
      "export_cross_template_insights": true
    }
  },
  "personalization": {
    "life_stage_detection": {
      "young_adult": ["college-selection", "first-job-transition", "apartment-hunting"],
      "family_building": ["wedding-planning", "home-buying", "baby-planning"],
      "career_focused": ["skill-development", "business-launch", "professional-networking"],
      "midlife": ["career-plateau", "caring-for-aging-parents", "midlife-crisis"],
      "pre_retirement": ["retirement-planning", "estate-planning", "downsizing-decisions"]
    },
    "priority_weighting": {
      "financial_focused": "boost financial_security_building cluster",
      "family_focused": "boost family_life_transitions cluster",
      "career_focused": "boost career_development_path cluster",
      "health_focused": "boost health_wellness_journey cluster"
    },
    "adaptive_suggestions": {
      "based_on_completed_templates": true,
      "consider_time_since_last_use": true,
      "factor_in_seasonal_relevance": true,
      "account_for_major_life_events": true
    }
  },
  "notification_triggers": {
    "new_related_template": "when user completes template with strong connections",
    "sequence_next_step": "when user shows progress in life sequence",
    "influence_alert": "when user selects template that triggers many others",
    "cluster_completion": "when user completes most templates in a cluster",
    "conflict_warning": "when user selects conflicting templates"
  },
  "analytics_tracking": {
    "connection_usage": "track which template connections users follow most",
    "prompt_effectiveness": "track which cross-template prompts users find helpful",
    "sequence_adherence": "track how often users follow suggested life sequences",
    "cluster_patterns": "identify which clusters users complete together"
  }
}