<parameter name="old_string">  {
    id: 'prompt-19',
    prompt: 'Identify and organize all financial accounts and passwords using a secure password manager to establish complete account oversight',
    category: 'planning',
    helpText: 'After bankruptcy, having complete visibility and control over all your financial accounts is essential for monitoring your recovery progress and preventing unauthorized activity. Create a comprehensive list of all bank accounts, credit monitoring services, loan accounts, and financial service logins, then secure them with strong, unique passwords using a reputable password manager. This organization ensures you can regularly monitor all accounts for accuracy, track your progress systematically, and quickly identify any suspicious activity that could threaten your financial recovery.'
  }
];</parameter>
<parameter name="new_string">  {
    id: 'prompt-19',
    prompt: 'Identify and organize all financial accounts and passwords using a secure password manager to establish complete account oversight',
    category: 'planning',
    helpText: 'After bankruptcy, having complete visibility and control over all your financial accounts is essential for monitoring your recovery progress and preventing unauthorized activity. Create a comprehensive list of all bank accounts, credit monitoring services, loan accounts, and financial service logins, then secure them with strong, unique passwords using a reputable password manager. This organization ensures you can regularly monitor all accounts for accuracy, track your progress systematically, and quickly identify any suspicious activity that could threaten your financial recovery.'
  },
  {
    id: 'prompt-20',
    prompt: 'Research and schedule a meeting with your employer\'s HR department to understand how bankruptcy affects your employment benefits and insurance options',
    category: 'research',
    helpText: 'Understanding how bankruptcy impacts your workplace benefits is crucial for maintaining essential coverage and making informed decisions about your employment future. Contact HR to clarify whether bankruptcy affects your health insurance, 401(k) contributions, life insurance policies, or other benefits, as some employers have policies that could impact your coverage or eligibility. This conversation also helps you understand your rights as an employee and ensures you\'re maximizing available benefits during your financial recovery period.'
  }
];</parameter>
</invoke>
