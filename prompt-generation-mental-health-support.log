<parameter name="old_string">  {
    id: 'prompt-38',
    prompt: 'Begin implementing one evidence-based coping skill daily for the next two weeks and track its effectiveness in your symptom journal',
    category: 'action',
    helpText: 'Actively practicing coping strategies builds your mental health toolkit and helps you identify which techniques work best for your specific symptoms and situations. Choose one technique like deep breathing, progressive muscle relaxation, or cognitive reframing, then commit to using it daily while noting its impact on your mood and stress levels. This consistent practice helps make coping skills automatic responses during difficult moments and provides concrete data about what strategies are most effective for your recovery journey.'
  }
];</parameter>
<parameter name="new_string">  {
    id: 'prompt-38',
    prompt: 'Begin implementing one evidence-based coping skill daily for the next two weeks and track its effectiveness in your symptom journal',
    category: 'action',
    helpText: 'Actively practicing coping strategies builds your mental health toolkit and helps you identify which techniques work best for your specific symptoms and situations. Choose one technique like deep breathing, progressive muscle relaxation, or cognitive reframing, then commit to using it daily while noting its impact on your mood and stress levels. This consistent practice helps make coping skills automatic responses during difficult moments and provides concrete data about what strategies are most effective for your recovery journey.'
  },
  {
    id: 'prompt-39',
    prompt: 'Schedule and attend a mental health first aid training course to better understand and support yourself and others during mental health crises',
    category: 'action',
    helpText: 'Mental health first aid training provides you with practical skills to recognize warning signs, offer initial support, and connect people to appropriate resources during mental health emergencies. These courses teach evidence-based techniques for de-escalation, crisis intervention, and supportive communication that benefit both your own recovery and your ability to help others. Look for certified courses through organizations like the National Council for Mental Wellbeing or local community health centers.'
  }
];</parameter>
</invoke>
